# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trader:trader_pass@localhost:5432/tradingdb

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ─── Telegram Alerts ───────────────────────────────────────────────────────────
# Get bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPqRsTuVwXyZ
TELEGRAM_CHAT_ID=987654321
TELEGRAM_ADMIN_CHAT_ID=987654321   # optional, defaults to TELEGRAM_CHAT_ID

# ─── Sentiment APIs (all optional — bot degrades gracefully without them) ──────
TWITTER_BEARER_TOKEN=your_twitter_v2_bearer_token
CRYPTOPANIC_API_KEY=your_key_from_cryptopanic.com   # free tier available
REDDIT_CLIENT_ID=your_reddit_app_id
REDDIT_SECRET=your_reddit_app_secret

# ─── Exchange API Keys (only needed for live trading, not paper mode) ───────────
# Leave blank to run in paper-only mode
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── Bot Defaults (can be overridden per-user via API) ─────────────────────────
DEFAULT_PAPER_MODE=true
DEFAULT_MAX_RISK_PCT=1.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
DEFAULT_KILL_SWITCH_DD_PCT=10.0
